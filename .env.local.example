# Google Analytics 4 - get your Measurement ID from analytics.google.com
# Analytics only loads when set and NODE_ENV=production
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Kit (ConvertKit) newsletter form - get from app.kit.com → Grow → Forms → Embed
# Form only shows when both are set
NEXT_PUBLIC_KIT_FORM_UID=your_form_uid
NEXT_PUBLIC_KIT_FORM_SCRIPT_URL=https://yoursite.ck.page/yourform.js

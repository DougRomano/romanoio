# Google Analytics 4 - get your Measurement ID from analytics.google.com
# Analytics only loads when set and NODE_ENV=production
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Kit (ConvertKit) newsletter form - get form ID from app.kit.com → Grow → Forms → Embed (HTML tab)
# Form ID is in the form action URL: .../forms/9195403/subscriptions
# Optional - defaults to 9195403 if not set
NEXT_PUBLIC_KIT_FORM_ID=9195403
